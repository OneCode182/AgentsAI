{
  "$schema": "Environment configuration for TecniPass harness",
  "version": "1.0.0",
  "active_environment": "windows-local",
  "paths": {
    "frontend": "${TECNI_FRONTEND}",
    "backend": "${TECNI_BACKEND}",
    "harness": "${TECNI_HARNESS}"
  },
  "environments": {
    "windows-local": {
      "TECNI_FRONTEND": "C:\\tecni\\tecnipass-frontend",
      "TECNI_BACKEND": "C:\\tecni\\tecnipass-backend",
      "TECNI_HARNESS": "D:\\\\AgentsAI\\\\.tecnipass",
      "SONAR_SERVER": ""
    },
    "linux-onecode": {
      "TECNI_FRONTEND": "/home/onecode/data/tecnipass-frontend",
      "TECNI_BACKEND": "/home/onecode/data/tecnipass-backend",
      "TECNI_HARNESS": "/home/onecode/Documents/Obsidian Vault/TECNI/.tecnipass",
      "SONAR_SERVER": ""
    },
    "sandbox": {
      "TECNI_FRONTEND": "/sessions/*/mnt/tecnipass-frontend",
      "TECNI_BACKEND": "/sessions/*/mnt/tecnipass-backend",
      "TECNI_HARNESS": "/sessions/*/mnt/TECNI/.tecnipass",
      "SONAR_SERVER": ""
    }
  },
  "services": {
    "sonarqube": {
      "url": "http://localhost:9005",
      "token": "${SONAR_SERVER}",
      "project_keys": {
        "frontend": "Tecnipass-Frontend",
        "backend": "Tecnipass-Backend"
      }
    },
    "linear": {
      "team": "TEC",
      "issue_format": "TEC-XXX"
    }
  },
  "runtime_capabilities": {
    "detection_strategy": "inspect_current_session_tools",
    "portable_workflow": true,
    "required": ["analysis", "code-editing", "filesystem"],
    "optional": [
      "shell",
      "tests",
      "web-search",
      "browser-inspection",
      "mcp",
      "subagents",
      "agent-team-execution",
      "parallel-execution",
      "task-board",
      "context-budget",
      "verification-retry",
      "decision-log",
      "computer-use",
      "inline-edit"
    ],
    "execution_modes": ["sequential", "parallel", "team"]
  }
}
